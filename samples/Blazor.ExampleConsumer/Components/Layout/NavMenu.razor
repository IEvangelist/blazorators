@inject NavigationManager Nav

<a class="brand" href="" @onclick=@(_ => OnNavigate.InvokeAsync())>
    <img src="logo.png" alt="" />
    <span>Blazorators</span>
</a>

<nav class="nav" aria-label="Primary">
    <div class="nav-section">Overview</div>
    <NavLink id="home" href="" Match="NavLinkMatch.All" @onclick=@(_ => OnNavigate.InvokeAsync())>
        <Icon Name="home" /> <span>Home</span>
    </NavLink>

    <div class="nav-section">Storage</div>
    <NavLink id="storage" href="todos" @onclick=@(_ => OnNavigate.InvokeAsync())>
        <Icon Name="list-check" /> <span>Local storage</span>
    </NavLink>

    <div class="nav-section">Location</div>
    <NavLink id="geolocation" href="geolocation" @onclick=@(_ => OnNavigate.InvokeAsync())>
        <Icon Name="map-pin" /> <span>Geolocation</span>
    </NavLink>
    <NavLink id="track" href="track" @onclick=@(_ => OnNavigate.InvokeAsync())>
        <Icon Name="route" /> <span>Watch position</span>
    </NavLink>

    <div class="nav-section">Speech</div>
    <NavLink id="tts" href="speak" @onclick=@(_ => OnNavigate.InvokeAsync())>
        <Icon Name="volume" /> <span>Text-to-speech</span>
    </NavLink>
    <NavLink id="stt" href="listen" @onclick=@(_ => OnNavigate.InvokeAsync())>
        <Icon Name="mic" /> <span>Speech-to-text</span>
    </NavLink>

    <div class="nav-section">Lab</div>
    <NavLink id="sandbox" href="sandbox" @onclick=@(_ => OnNavigate.InvokeAsync())>
        <Icon Name="rocket" /> <span>Sandbox</span>
    </NavLink>

    <div class="nav-section">Reference</div>
    <a id="code" href="https://github.com/IEvangelist/blazorators"
       target="_blank" rel="noopener noreferrer nofollow">
        <Icon Name="github" /> <span>Source code</span>
        <span class="ms-auto"><Icon Name="external-link" Class="icon-sm" /></span>
    </a>
</nav>

<div class="nav-footer">
    <span class="badge"><span class="badge-dot live" aria-hidden="true"></span> WASM ready</span>
    <div>Source-generated bindings for Blazor.</div>
</div>

@code {
    [Parameter] public EventCallback OnNavigate { get; set; }
}
