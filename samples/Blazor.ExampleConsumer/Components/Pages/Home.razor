            <div class="bento-anim bento-anim-stack">
                <div class="anim-storage-disk">
                    <Icon Name="database" Class="icon-sm" />
                    <span>localStorage</span>
                </div>
                <div class="anim-todo" style="--n:0">
                    <span class="anim-todo-check"><Icon Name="check" Class="icon-xs" /></span>
                    <span class="anim-todo-text">Ship bento UX</span>
                </div>
                <div class="anim-todo" style="--n:1">
                    <span class="anim-todo-check"><Icon Name="check" Class="icon-xs" /></span>
                    <span class="anim-todo-text">Wire spotlight</span>
