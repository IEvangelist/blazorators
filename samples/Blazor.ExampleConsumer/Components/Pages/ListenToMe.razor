@page "/listen"
<PageTitle>Speech-to-text · Blazorators</PageTitle>

<header class="page-header">
    <span class="hero-eyebrow">
        <span class="badge-dot live" aria-hidden="true"></span>
        Blazor.SpeechRecognition.WebAssembly
    </span>
    <h1>Speech-to-text</h1>
    <p>Source-generated bindings for the browser's Web Speech recognition API.</p>
</header>

<section class="card">
    <div class="field">
        <label class="field-label" for="text">Transcript</label>
        <textarea class="textarea"
                  id="text"
                  rows="6"
                  readonly=@_isRecognizingSpeech
                  placeholder="Click the mic and start talking…"
                  @bind=@_transcript></textarea>
    </div>

    <Code Value=@_errorEvent T=SpeechRecognitionErrorEvent IsError=true />

    <div class="mic-row">
        <button type="button"
                class="mic-btn @(_isRecognizingSpeech ? "recording" : null)"
                title="@(_isRecognizingSpeech ? "Stop" : "Listen")"
                aria-pressed="@_isRecognizingSpeech"
                @onclick=@OnRecognizeSpeechClick>
            @if (_isRecognizingSpeech)
            {
                <Icon Name="mic-off" />
            }
            else
            {
                <Icon Name="mic" />
            }
        </button>
        <span class="mic-label">
            @(_isRecognizingSpeech ? "Listening…" : "Tap to listen")
        </span>
    </div>
</section>

<RepositoryPrompt Title="Speech-to-text demo" />
