@page "/listen"

<PageTitle>Speech-to-text</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Speech-to-text</MudText>

<MudText Typo="Typo.body1" Class="mb-4">
    This page demonstrates the source generated <code>Blazor.SpeechRecognition.WebAssembly</code> package.
</MudText>

<MudGrid>
    <MudItem xs="12" md="8">
        <MudTextField @bind-Value="_transcript"
                     T="string"
                     Label="Speech-to-text"
                     Variant="Variant.Outlined"
                     Lines="6"
                     FullWidth="true"
                     ReadOnly="_isRecognizingSpeech"
                     Class="mb-4" />

        <MudButton Color="@(_isRecognizingSpeech ? Color.Error : Color.Primary)"
                  Variant="Variant.Filled"
                  Size="Size.Large"
                  StartIcon="@(_isRecognizingSpeech ? Icons.Material.Filled.Stop : Icons.Material.Filled.Mic)"
                  OnClick="OnRecognizeSpeechClick">
            @(_isRecognizingSpeech ? "Stop" : "Listen")
        </MudButton>
    </MudItem>
</MudGrid>

<Code Value=@_errorEvent T=SpeechRecognitionErrorEvent IsError=true />