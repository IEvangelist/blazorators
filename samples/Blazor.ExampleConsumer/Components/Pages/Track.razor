@page "/track"
<PageTitle>Watch position · Blazorators</PageTitle>

<header class="page-header">
    <span class="hero-eyebrow">
        <span class="badge-dot live" aria-hidden="true"></span>
        Blazor.Geolocation.WebAssembly
    </span>
    <h1>
        Watch position
        @if (_isLoading)
        {
            <span class="spinner" role="status" aria-live="polite">
                <span class="visually-hidden">Loading…</span>
            </span>
        }
        else
        {
            <span class="badge">
                <span class="badge-dot live" aria-hidden="true"></span>
                WATCHING
            </span>
        }
        @if (_position is not null)
        {
            <span class="badge">
                @(_position.TimestampAsUtcDateTime.ToLocalTime().ToString("T"))
            </span>
            <a class="link-icon"
               href="https://www.nuget.org/packages/Blazor.Geolocation.WebAssembly"
               target="_blank" rel="noopener noreferrer nofollow"
               title="View package on NuGet" aria-label="View package on NuGet">
                <Icon Name="external-link" Class="icon-sm" />
            </a>
        }
    </h1>
    @if (_isLoading)
    {
        <p>Subscribes to live <code>watchPosition</code> updates. The map
           re-centers on every callback.</p>
    }
</header>

<div class="stack">
    <Code Value=@_position T=GeolocationPosition IsError=false />
    <Code Value=@_positionError T=GeolocationPositionError IsError=true />

    <Map Position=@_position />
</div>

<RepositoryPrompt Title="Watch position demo" />
