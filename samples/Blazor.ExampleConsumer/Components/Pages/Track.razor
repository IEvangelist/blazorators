@page "/track"

<PageTitle>Track</PageTitle>

<div class="d-flex align-items-center mb-3">
    <MudText Typo="Typo.h4" Class="mr-2">Geolocation Tracking</MudText>
    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
    }
    @if (_position is not null)
    {
        <MudChip Color="Color.Primary" Size="Size.Small" Icon="Icons.Material.Filled.Schedule">
            @(_position.TimestampAsUtcDateTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss"))
        </MudChip>
        <MudIconButton Icon="Icons.Material.Filled.OpenInNew" 
                       Color="Color.Primary" 
                       Size="Size.Small"
                       Href="https://www.nuget.org/packages/Blazor.Geolocation.WebAssembly" 
                       Target="_blank" />
    }
</div>

@if (_isLoading)
{
    <MudText Typo="Typo.body1" Class="mb-4">
        This page demonstrates the source generated <code>Blazor.Geolocation.WebAssembly</code> package.
    </MudText>
}

@{
    <Code Value=@_position T=GeolocationPosition IsError=false />
    <Code Value=@_positionError T=GeolocationPositionError IsError=true />

    <BingMap Position=@_position />
}