@page "/todos"

<PageTitle>Tasks</PageTitle>

<div class="d-flex align-items-center mb-3">
    <MudText Typo="Typo.h4" Class="mr-2">Local Storage</MudText>
    <MudIconButton Icon="Icons.Material.Filled.OpenInNew" 
                   Color="Color.Primary" 
                   Size="Size.Small"
                   Href="https://www.nuget.org/packages/Blazor.LocalStorage.WebAssembly" 
                   Target="_blank" />
</div>

<MudText Typo="Typo.body1" Class="mb-4">
    This page demonstrates the source generated <code>Blazor.LocalStorage.WebAssembly</code> package.
</MudText>

<MudCard Elevation="2">
    <MudCardContent Class="pa-6">
        <div class="d-flex align-items-center gap-2 mb-4">
            <MudTextField @bind-Value="_todoValue" 
                         T="string"
                         Label="New task..."
                         Variant="Variant.Outlined"
                         FullWidth="true"
                         @onkeyup="@OnKeyUp"
                         AutoFocus="true" />
            <MudButton Color="Color.Primary" 
                      Variant="Variant.Filled" 
                      OnClick="AddNewTodo"
                      StartIcon="Icons.Material.Filled.Add">
                Add
            </MudButton>
            <MudButton Color="Color.Error" 
                      Variant="Variant.Outlined" 
                      OnClick="ClearAll"
                      StartIcon="Icons.Material.Filled.Clear">
                Clear All
            </MudButton>
        </div>
        
        @if (_todos is { Count: > 0 })
        {
            <MudList Clickable="false">
                @foreach (var todo in _todos)
                {
                    <MudListItem Class="pa-2">
                        <div class="d-flex align-items-center justify-space-between w-100">
                            <StorageCheckbox Item="@todo" ItemChanged="@OnItemChanged" />
                            <MudIconButton Icon="Icons.Material.Filled.Delete" 
                                          Color="Color.Error" 
                                          Size="Size.Small"
                                          OnClick="@(_ => Delete(todo))" />
                        </div>
                    </MudListItem>
                }
            </MudList>
        }
    </MudCardContent>
</MudCard>

@if (_localStorageItems is { Count: > 0 })
{
    <MudCard Elevation="1" Class="mt-4">
        <MudExpansionPanels Elevation="0">
            <MudExpansionPanel>
                <TitleContent>
                    <div class="d-flex align-items-center">
                        <MudIcon Icon="Icons.Material.Filled.Storage" Class="mr-3" />
                        <MudText>Raw <code>window.localStorage</code> values</MudText>
                    </div>
                </TitleContent>
                <ChildContent>
                    <MudTable Items="_localStorageItems" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>#</MudTh>
                            <MudTh>Key</MudTh>
                            <MudTh>Value</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="#">@((_localStorageItems.ToList().IndexOf(context)) + 1)</MudTd>
                            <MudTd DataLabel="Key"><code>@context.Key</code></MudTd>
                            <MudTd DataLabel="Value"><code>@context.Value</code></MudTd>
                        </RowTemplate>
                    </MudTable>
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </MudCard>
}