@page "/speak"
<PageTitle>Text-to-speech · Blazorators</PageTitle>

<header class="page-header">
    <span class="hero-eyebrow">
        <span class="badge-dot live" aria-hidden="true"></span>
        Blazor.SpeechSynthesis.WebAssembly
    </span>
    <h1>Text-to-speech</h1>
    <p>Source-generated bindings for the Web Speech API. Pick a voice,
       drag the rate slider, and hit speak.</p>
</header>

<section class="card">
    <div class="field">
        <label class="field-label" for="voice">
            <Icon Name="languages" Class="icon-sm" /> Voice
        </label>
        <div class="input-group">
            <select id="voice" class="select"
                    @bind=_selectedVoice
                    disabled=@(_voices?.Any() is false)
                    aria-label="Voice selection">
                @foreach (var voice in _voices ?? Array.Empty<SpeechSynthesisVoice>())
                {
                    <option value="@voice.Name">@voice.Name</option>
                }
            </select>
            <button class="btn btn-ghost btn-icon"
                    type="button"
                    title="Refresh voices"
                    aria-label="Refresh voices"
                    @onclick=@(async () => await GetVoicesAsync())>
                <Icon Name="refresh" />
            </button>
        </div>
    </div>

    <div class="field">
        <label class="field-label" for="range">
            Voice speed
            <span class="kbd">@_voiceSpeed.ToString("0.00")×</span>
        </label>
        <input type="range"
               min="@_voiceSpeeds.Min()"
               max="@_voiceSpeeds.Max()"
               step=".25"
               class="range"
               id="range"
               list="speeds"
               value="@_voiceSpeed"
               @onchange=@OnVoiceSpeedChange />
        <datalist id="speeds">
            @foreach (var speed in _voiceSpeeds)
            {
                <option value="@speed">speed</option>
            }
        </datalist>
    </div>

    <div class="field">
        <label class="field-label" for="text">
            Text
            @if (_elapsedTimeMessage is { Length: > 0 })
            {
                <span class="badge">
                    <span class="badge-dot live" aria-hidden="true"></span>
                    @_elapsedTimeMessage
                </span>
            }
        </label>
        <textarea class="textarea" id="text"
                  rows="4"
                  @oninput=@OnTextChanged
                  value=@_text></textarea>
    </div>

    <div class="btn-group btn-group-segmented" role="group" aria-label="Speech playback">
        <button type="button" class="btn btn-primary" @onclick=@Speak>
            <Icon Name="play" /> <span>Speak</span>
        </button>
        <button type="button" class="btn btn-ghost btn-icon"
                title="Pause" aria-label="Pause" @onclick=@speechSynthesis.Pause>
            <Icon Name="pause" />
        </button>
        <button type="button" class="btn btn-ghost btn-icon"
                title="Resume" aria-label="Resume" @onclick=@speechSynthesis.Resume>
            <Icon Name="play" />
        </button>
        <button type="button" class="btn btn-ghost btn-icon btn-icon-danger"
                title="Stop" aria-label="Stop" @onclick=@speechSynthesis.Cancel>
            <Icon Name="square" />
        </button>
    </div>
</section>

<RepositoryPrompt Title="Text-to-speech demo" />
