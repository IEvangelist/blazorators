@typeparam T where T : class

@if (Value is not null)
{
    <MudCard Elevation="1" Class="mt-4">
        <MudCardContent>
            <MudText Typo="Typo.caption" Class="mb-2" Color="@(_color)">
                @typeof(T).Name
            </MudText>
            <MudPaper Elevation="0" Class="pa-3" Style="background-color: var(--mud-palette-dark); color: var(--mud-palette-white); font-family: 'Courier New', monospace; overflow-x: auto;">
                <pre style="margin: 0; white-space: pre-wrap;">@{
                    var opts = new JsonSerializerOptions()
                    {
                        WriteIndented = true,
                        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
                    };
                }@Value?.ToJson(opts)</pre>
            </MudPaper>
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter, EditorRequired]
    public T? Value { get; set; } = default!;

    [Parameter]
    public bool IsError { get; set; }

    Color _color => IsError ? Color.Warning : Color.Info;
}
