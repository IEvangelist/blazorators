<aside class="source-prompt" aria-label="@(string.IsNullOrWhiteSpace(Title) ? "Source code" : $"{Title} source code")">
    <div class="source-prompt-meta">
        <span class="source-prompt-kicker">
            <Icon Name="code" Class="icon-sm" />
            Source
        </span>
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <span class="source-prompt-title">@Title</span>
        }
    </div>
    <a class="source-prompt-link"
       target="_blank" rel="noopener noreferrer"
       href="https://github.com/IEvangelist/blazorators">
        <Icon Name="github" Class="icon-sm" />
        <span>View on GitHub</span>
        <Icon Name="arrow-up-right" Class="icon-sm source-prompt-arrow" />
    </a>
</aside>

@code {
    [Parameter] public string? Title { get; set; }
}
