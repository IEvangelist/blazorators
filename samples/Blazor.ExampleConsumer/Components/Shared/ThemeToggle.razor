@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="theme-toggle" role="group" aria-label="Theme">
    <button type="button"
            aria-label="Light theme"
            aria-pressed="@(_theme == "light")"
            title="Light"
            @onclick=@(() => SetAsync("light"))>
        <Icon Name="sun" />
    </button>
    <button type="button"
            aria-label="System theme"
            aria-pressed="@(_theme == "system")"
            title="System"
            @onclick=@(() => SetAsync("system"))>
        <Icon Name="monitor" />
    </button>
    <button type="button"
            aria-label="Dark theme"
            aria-pressed="@(_theme == "dark")"
            title="Dark"
            @onclick=@(() => SetAsync("dark"))>
        <Icon Name="moon" />
    </button>
</div>

@code {
    IJSObjectReference? _module;
    DotNetObjectReference<ThemeToggle>? _selfRef;
    int? _subscriptionId;

    string _theme = "system";
    string _resolved = "light";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./theme.js");
        _theme = await _module.InvokeAsync<string>("getTheme");
        _resolved = await _module.InvokeAsync<string>("getResolved");
        _selfRef = DotNetObjectReference.Create(this);
        _subscriptionId = await _module.InvokeAsync<int>("subscribe", _selfRef);
        StateHasChanged();
    }

    async Task SetAsync(string value)
    {
        if (_module is null)
        {
            return;
        }
        _theme = value;
        _resolved = await _module.InvokeAsync<string>("setTheme", value);
        StateHasChanged();
    }

    [JSInvokable]
    public Task OnThemeChanged(string resolved)
    {
        _resolved = resolved;
        return InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null && _subscriptionId is int id)
        {
            try { await _module.InvokeVoidAsync("unsubscribe", id); }
            catch { /* ignore */ }
        }
        _selfRef?.Dispose();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch { /* ignore */ }
        }
    }
}
